<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vol. {{ meta.vol }} — {{ meta.title_plain or meta.title }} — Antifragile Africa Crypto</title>
<meta name="description" content="{{ (meta.standfirst or '')[:160] }}">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=IBM+Plex+Mono:wght@300;400;500&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root{--navy:#00355f;--steel:#7399c6;--sky:#acd4f1;--charcoal:#231f20;--mid:#58575a;--white:#ffffff;--gold:#c9a84c;--bg:#0a1a2a;--surface:#0f2236;--surface2:#162d46;--surface3:#1c3554;--border:rgba(115,153,198,0.18);--border-s:rgba(115,153,198,0.35);--green:#4fc98a;--red:#e05c5c;}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{background:var(--bg);color:var(--white);font-family:'Source Serif 4',Georgia,serif;font-weight:300;line-height:1.75;font-size:16px;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:.4;}
  nav{position:sticky;top:0;z-index:200;background:rgba(10,26,42,0.97);backdrop-filter:blur(14px);border-bottom:1px solid var(--border-s);height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;}
  .nb{font-family:'Playfair Display',serif;font-weight:900;font-size:.95rem;color:var(--white);letter-spacing:-.01em;text-decoration:none;}
  .nb span{color:var(--sky);font-style:italic;}
  .nl{display:flex;gap:2.5rem;align-items:center;list-style:none;}
  .nl a{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mid);text-decoration:none;transition:color .2s;}
  .nl a:hover{color:var(--steel);}
  .nav-cta{color:var(--sky)!important;border:1px solid rgba(172,212,241,.35);padding:.3rem .9rem;transition:background .2s!important;}
  .nav-cta:hover{background:rgba(172,212,241,.1)!important;}
  .ih{background:var(--surface);border-bottom:1px solid var(--border-s);padding:5rem 3rem 4rem;position:relative;overflow:hidden;}
  .ih::before{content:'{{ meta.vol_roman or meta.vol }}';position:absolute;right:-.02em;top:-.12em;font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(10rem,24vw,22rem);color:transparent;-webkit-text-stroke:1px rgba(115,153,198,.06);line-height:1;pointer-events:none;user-select:none;}
  .ih-inner{max-width:1140px;margin:0 auto;position:relative;z-index:2;}
  .chips{display:flex;gap:2.5rem;margin-bottom:1.8rem;flex-wrap:wrap;align-items:center;}
  .chip{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;display:flex;flex-direction:column;gap:.12rem;}
  .chip-l{color:var(--mid);}
  .chip-v{color:var(--sky);}
  .chip-div{width:1px;height:30px;background:var(--border);}
  .badge{font-family:'IBM Plex Mono',monospace;font-size:.56rem;letter-spacing:.18em;text-transform:uppercase;padding:.22rem .65rem;display:inline-block;}
  .badge-vol{background:var(--steel);color:var(--bg);}
  .badge-alert{background:rgba(224,92,92,.15);color:var(--red);border:1px solid rgba(224,92,92,.3);}
  .badge-gold{background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3);}
  .badge-confirmed{background:rgba(79,201,138,.15);color:var(--green);border:1px solid rgba(79,201,138,.3);}
  .badges{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.5rem;}
  .ih-date{font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.1em;color:var(--mid);margin-bottom:1.2rem;}
  .ih-title{font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(2.2rem,4.8vw,4rem);line-height:1.05;letter-spacing:-.025em;color:var(--white);margin-bottom:1.2rem;max-width:820px;}
  .ih-title em{color:var(--sky);font-style:italic;}
  .ih-sub{font-size:1.05rem;color:rgba(255,255,255,.52);line-height:1.68;max-width:640px;margin-bottom:2.5rem;}
  .ih-nav{display:flex;gap:.5rem;flex-wrap:wrap;}
  .ih-nav a{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);text-decoration:none;border:1px solid var(--border);padding:.28rem .65rem;transition:color .15s,border-color .15s;}
  .ih-nav a:hover{color:var(--sky);border-color:var(--steel);}
  .sb{background:var(--surface2);border-bottom:1px solid var(--border);}
  .sb-inner{max-width:1140px;margin:0 auto;padding:0 3rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));}
  .sc{padding:1.1rem 1.4rem;border-right:1px solid var(--border);}
  .sc:last-child{border-right:none;}
  .sc-country{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.18em;text-transform:uppercase;color:var(--mid);margin-bottom:.3rem;}
  .sc-val{font-family:'Playfair Display',serif;font-weight:700;font-size:1.55rem;line-height:1;color:var(--white);}
  .sc-val.alert{color:var(--red);}.sc-val.gold{color:var(--gold);}.sc-val.green{color:var(--green);}
  .sc-trend{font-family:'IBM Plex Mono',monospace;font-size:.58rem;}
  .sc-note{font-size:.7rem;color:rgba(255,255,255,.35);line-height:1.35;margin-top:.2rem;}
  .t-up{color:var(--green);}.t-down{color:var(--red);}.t-alert{color:var(--red);font-weight:500;}.t-gold{color:var(--gold);}.t-neutral{color:var(--sky);}
  .container{max-width:1140px;margin:0 auto;padding:0 3rem;}
  .rs{padding:4.5rem 0;border-bottom:1px solid var(--border);}
  .rs:last-of-type{border-bottom:none;}
  .s-num{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--steel);background:rgba(115,153,198,.08);border:1px solid var(--border);padding:.18rem .55rem;display:inline-block;margin-bottom:.75rem;}
  .s-ey{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.28em;text-transform:uppercase;color:var(--steel);display:flex;align-items:center;gap:1rem;margin-bottom:1rem;}
  .s-ey::after{content:'';flex:1;height:1px;background:var(--border);max-width:80px;}
  h2{font-family:'Playfair Display',serif;font-weight:700;font-size:clamp(1.7rem,2.8vw,2.3rem);line-height:1.1;letter-spacing:-.02em;color:var(--white);margin-bottom:2rem;}
  h2 em{color:var(--sky);font-style:italic;}
  /* Executive Brief */
  .eb{background:var(--surface);border:1px solid var(--border-s);border-left:5px solid var(--sky);padding:3rem;margin-bottom:1.5rem;}
  .eb-hl{font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(1.3rem,2.2vw,1.85rem);line-height:1.15;color:var(--white);margin-bottom:1.8rem;text-transform:uppercase;letter-spacing:.015em;}
  .eb-body p{font-size:1.02rem;color:rgba(255,255,255,.82);line-height:1.87;margin-bottom:1.3rem;}
  .eb-body p:last-child{margin-bottom:0;}
  .eb-body strong{color:var(--white);font-weight:600;}
  .eb-body em{color:var(--sky);font-style:italic;}
  .eb-sum{font-family:'IBM Plex Mono',monospace;font-size:.75rem;letter-spacing:.08em;color:var(--sky);border-top:1px solid var(--border);padding-top:1.2rem;margin-top:1.8rem;line-height:1.65;}
  .eb-risk{font-family:'IBM Plex Mono',monospace;font-size:.67rem;letter-spacing:.07em;color:var(--mid);border-top:1px solid var(--border);padding-top:.9rem;margin-top:1rem;line-height:1.6;}
  .eb-risk strong{color:rgba(255,255,255,.55);}
  /* Insights */
  .ins-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
  .ins-card{background:var(--surface);border:1px solid var(--border);padding:1.8rem 2rem;position:relative;overflow:hidden;transition:border-color .2s;}
  .ins-card:hover{border-color:var(--steel);}
  .ins-card::after{content:attr(data-n);position:absolute;bottom:-.4em;right:.5rem;font-family:'Playfair Display',serif;font-weight:900;font-size:8rem;color:rgba(115,153,198,.04);line-height:1;pointer-events:none;}
  .conf{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;padding:.15rem .5rem;border:1px solid;display:inline-block;margin-bottom:.75rem;}
  .conf-h{color:var(--green);border-color:rgba(79,201,138,.3);background:rgba(79,201,138,.07);}
  .conf-m{color:var(--gold);border-color:rgba(201,168,76,.3);background:rgba(201,168,76,.07);}
  .conf-l{color:var(--mid);border-color:var(--border);}
  .ins-head{font-family:'Playfair Display',serif;font-weight:700;font-size:1.02rem;color:var(--white);margin-bottom:.7rem;line-height:1.3;}
  .ins-body{font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.72;}
  .ins-body strong{color:var(--white);font-weight:600;}
  .ins-body em{color:var(--sky);}
  .ins-src{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);margin-top:.9rem;padding-top:.75rem;border-top:1px solid var(--border);}
  /* Heat Map */
  .hm-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:1.5rem;}
  .hm-cell{background:var(--surface);padding:1rem;transition:background .15s;}
  .hm-cell:hover{background:var(--surface2);}
  .l-red{border-left:3px solid var(--red);}.l-gold{border-left:3px solid var(--gold);}
  .l-steel{border-left:3px solid var(--steel);}.l-dim{border-left:3px solid rgba(115,153,198,.28);}.l-green{border-left:3px solid var(--green);}
  .hm-country{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);margin-bottom:.28rem;}
  .hm-score{font-family:'Playfair Display',serif;font-weight:900;font-size:1.65rem;line-height:1;}
  .c-r{color:var(--red);}.c-g{color:var(--gold);}.c-s{color:var(--steel);}.c-gr{color:var(--green);}
  .hm-trend{font-family:'IBM Plex Mono',monospace;font-size:.56rem;}
  .hm-note{font-size:.68rem;color:rgba(255,255,255,.38);line-height:1.35;margin-top:.2rem;}
  .hm-caption{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--steel);padding:1.5rem 2rem;margin-bottom:1.5rem;}
  .hm-caption p{font-size:.92rem;color:rgba(255,255,255,.72);line-height:1.75;}
  .hm-caption strong{color:var(--white);}
  .mv-alert{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.28);padding:1rem 1.5rem;margin-bottom:.8rem;display:flex;gap:1.2rem;}
  .mv-label{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);white-space:nowrap;padding-top:.08rem;}
  .mv-body{font-size:.87rem;color:rgba(255,255,255,.72);line-height:1.65;}
  .mv-body strong{color:var(--white);}
  /* Full Stack */
  .sw{display:grid;grid-template-columns:200px 1fr;gap:3.5rem;align-items:start;}
  .st{position:sticky;top:80px;}
  .toc-l{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--steel);margin-bottom:1rem;display:block;}
  .toc-list{list-style:none;border-left:1px solid var(--border);}
  .toc-list a{display:block;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.08em;color:var(--mid);text-decoration:none;padding:.42rem .8rem;border-left:2px solid transparent;margin-left:-1px;transition:color .15s,border-color .15s;line-height:1.4;}
  .toc-list a:hover{color:var(--sky);border-left-color:var(--steel);}
  .sl{margin-bottom:3rem;padding-bottom:3rem;border-bottom:1px solid var(--border);scroll-margin-top:80px;}
  .sl:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
  .lb{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--steel);background:rgba(115,153,198,.09);border:1px solid var(--border);padding:.14rem .5rem;display:inline-block;margin-bottom:.65rem;}
  .lt{font-family:'Playfair Display',serif;font-weight:700;font-size:1.18rem;color:var(--white);margin-bottom:1rem;letter-spacing:-.01em;}
  .lbody p{font-size:.96rem;color:rgba(255,255,255,.78);line-height:1.83;margin-bottom:1.15rem;}
  .lbody p:last-child{margin-bottom:0;}
  .lbody strong{color:var(--white);font-weight:600;}
  .lbody em{color:var(--sky);font-style:italic;}
  .ob{background:var(--surface2);border:1px solid var(--border);padding:1.2rem 1.5rem;margin:1.2rem 0;display:grid;grid-template-columns:80px 1fr;gap:1rem;}
  .ot{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;color:var(--steel);padding-top:.1rem;}
  .od{font-size:.88rem;color:rgba(255,255,255,.72);line-height:1.68;}
  .od strong{color:var(--white);font-weight:600;}
  .cross-box{background:var(--surface2);border:1px solid var(--border-s);border-left:4px solid var(--steel);padding:2rem 2.5rem;margin-top:2.5rem;}
  .cross-lbl{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--steel);display:block;margin-bottom:1.5rem;}
  .ci{margin-bottom:1.8rem;padding-bottom:1.8rem;border-bottom:1px solid var(--border);}
  .ci:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none;}
  .ci-t{font-family:'Playfair Display',serif;font-style:italic;font-size:1rem;color:var(--sky);margin-bottom:.65rem;}
  .ci-b{font-size:.9rem;color:rgba(255,255,255,.65);line-height:1.72;}
  .ci-b strong{color:var(--white);font-weight:600;}
  /* Fragility */
  .ft{display:grid;grid-template-columns:auto 1fr;gap:3rem;background:var(--surface);border:1px solid var(--border);padding:2rem 2.5rem;margin-bottom:1.5rem;align-items:center;}
  .fs{font-family:'Playfair Display',serif;font-weight:900;font-size:5rem;line-height:1;}
  .fs.med{color:var(--gold);}.fs.low{color:var(--green);}.fs.high{color:var(--red);}
  .fm{display:flex;flex-direction:column;gap:.5rem;}
  .fst{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;}
  .fst.low-color{color:var(--green);}.fst.high-color{color:var(--red);}.fst.med-color{color:var(--gold);}
  .fd{font-size:.9rem;color:rgba(255,255,255,.62);line-height:1.65;}
  .fbars{background:var(--surface);border:1px solid var(--border);padding:2rem 2.5rem;margin-bottom:2rem;}
  .fr{display:flex;align-items:center;gap:1.2rem;padding:.7rem 0;border-bottom:1px solid var(--border);}
  .fr:last-child{border-bottom:none;padding-bottom:0;}
  .frl{font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.1em;color:var(--mid);flex:1;}
  .fbw{flex:2;height:5px;background:rgba(115,153,198,.14);}
  .fb{height:100%;}
  .fb-low{background:var(--steel);}.fb-med{background:var(--gold);}.fb-high{background:var(--red);}
  .fv{font-family:'Playfair Display',serif;font-weight:700;font-size:1.05rem;color:var(--white);min-width:28px;text-align:right;}
  .risks{display:flex;flex-direction:column;gap:1rem;}
  .ri{background:var(--surface);border:1px solid var(--border);padding:1.5rem 2rem;display:grid;grid-template-columns:auto 1fr auto;gap:1.5rem;align-items:flex-start;}
  .rr{font-family:'Playfair Display',serif;font-weight:900;font-size:2rem;color:rgba(115,153,198,.3);line-height:1;}
  .rn{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--steel);margin-bottom:.5rem;}
  .rd{font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.65;}
  .rl{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;padding:.2rem .5rem;white-space:nowrap;}
  .risk-high{background:rgba(224,92,92,.12);color:var(--red);border:1px solid rgba(224,92,92,.25);}
  .risk-med{background:rgba(201,168,76,.1);color:var(--gold);border:1px solid rgba(201,168,76,.22);}
  .risk-low{background:rgba(115,153,198,.1);color:var(--steel);border:1px solid var(--border);}
  /* Opportunities */
  .opp-list{display:flex;flex-direction:column;gap:2rem;}
  .oc{background:var(--surface);border:1px solid var(--border);overflow:hidden;transition:border-color .2s;}
  .oc:hover{border-color:var(--steel);}
  .oh{background:var(--surface2);border-bottom:1px solid var(--border);padding:1.5rem 2rem;display:flex;gap:2rem;align-items:flex-start;flex-wrap:wrap;}
  .otb{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;background:var(--steel);color:var(--bg);padding:.2rem .6rem;white-space:nowrap;flex-shrink:0;}
  .ott{font-family:'Playfair Display',serif;font-weight:700;font-size:1.28rem;color:var(--white);flex:1;min-width:200px;line-height:1.25;}
  .os{text-align:right;}
  .osn{font-family:'Playfair Display',serif;font-weight:900;font-size:2.2rem;color:var(--green);line-height:1;}
  .osl{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);}
  .ob2{padding:2rem;display:grid;grid-template-columns:1fr 260px;gap:2rem;}
  .oth p{font-size:.95rem;color:rgba(255,255,255,.75);line-height:1.8;margin-bottom:1.1rem;}
  .oth p:last-child{margin-bottom:0;}
  .oth strong{color:var(--white);font-weight:600;}
  .omc{display:flex;flex-direction:column;gap:.8rem;}
  .oml{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:var(--mid);display:block;margin-bottom:.2rem;}
  .omv{font-size:.82rem;color:var(--sky);line-height:1.5;}
  .oi{border-top:1px solid var(--border);padding:.9rem 2rem;font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.07em;color:var(--mid);}
  .oi strong{color:rgba(255,255,255,.5);}
  /* Power Map */
  .pm-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem;}
  .pb{background:var(--surface);border:1px solid var(--border);padding:1.8rem 2rem;}
  .pb-title{font-family:'Playfair Display',serif;font-weight:700;font-size:1.08rem;color:var(--white);margin-bottom:1.2rem;border-bottom:1px solid var(--border);padding-bottom:.8rem;}
  .pr{display:flex;justify-content:space-between;padding:.52rem 0;border-bottom:1px solid rgba(115,153,198,.08);align-items:center;}
  .pr:last-child{border-bottom:none;padding-bottom:0;}
  .p-lbl{font-family:'IBM Plex Mono',monospace;font-size:.56rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);}
  .p-val{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.08em;}
  .p-state{color:var(--red);}.p-contested{color:var(--gold);}.p-crypto{color:var(--green);}
  .psa{background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--gold);padding:1.5rem 2rem;margin-bottom:1rem;}
  .psa.green-border{border-left-color:var(--green);}
  .psa-lbl{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:.5rem;display:block;}
  .psa-lbl.green{color:var(--green);}
  .psa-title{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:var(--white);margin-bottom:.5rem;}
  .psa-desc{font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.65;}
  .psa-desc strong{color:var(--white);font-weight:600;}
  /* Black Swan */
  .bs-list{display:flex;flex-direction:column;gap:1.2rem;}
  .bsc{background:var(--surface);border:1px solid var(--border);border-left:3px solid;display:grid;grid-template-columns:160px 1fr;}
  .bsc.s-remote{border-left-color:rgba(115,153,198,.35);}.bsc.s-low{border-left-color:var(--steel);}
  .bsc.s-med{border-left-color:var(--gold);}.bsc.s-pos{border-left-color:var(--green);}.bsc.s-high{border-left-color:var(--red);}
  .bs-pc{padding:1.5rem 1.2rem;background:var(--surface2);border-right:1px solid var(--border);display:flex;flex-direction:column;gap:.3rem;}
  .bs-pl{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mid);}
  .bs-pv{font-family:'Playfair Display',serif;font-weight:700;font-size:1.2rem;color:var(--white);line-height:1;}
  .bs-bc{padding:1.5rem 2rem;}
  .bs-bc h4{font-family:'Playfair Display',serif;font-weight:700;font-size:1.02rem;color:var(--white);margin-bottom:.6rem;}
  .bs-bc p{font-size:.87rem;color:rgba(255,255,255,.65);line-height:1.7;margin-bottom:.8rem;}
  .bs-bc p:last-child{margin-bottom:0;}
  .bs-bc strong{color:var(--white);font-weight:600;}
  .bs-tr{font-family:'IBM Plex Mono',monospace;font-size:.56rem;letter-spacing:.08em;color:var(--mid);margin-top:.7rem;padding-top:.7rem;border-top:1px solid var(--border);}
  .bs-tr strong{color:var(--sky);}
  /* Signal / Noise */
  .sn-table{width:100%;border-collapse:collapse;margin-bottom:1.5rem;}
  .sn-table th{text-align:left;padding:.6rem 1rem;font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;color:var(--steel);font-weight:400;border-bottom:1px solid var(--border-s);}
  .sn-table td{padding:.88rem 1rem;color:rgba(255,255,255,.72);border-bottom:1px solid var(--border);font-size:.87rem;line-height:1.55;vertical-align:top;}
  .sn-table tr:last-child td{border-bottom:none;}
  .sn-table tr:hover td{background:var(--surface);}
  .sn-dev{font-weight:400;color:var(--white);display:block;margin-bottom:.2rem;}
  .sn-b{font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;padding:.14rem .42rem;border:1px solid;display:inline-block;}
  .sn-ss{color:var(--sky);border-color:rgba(172,212,241,.3);background:rgba(172,212,241,.07);}
  .sn-s{color:var(--green);border-color:rgba(79,201,138,.3);background:rgba(79,201,138,.07);}
  .sn-n{color:var(--mid);border-color:var(--border);}
  .sn-u{color:var(--gold);border-color:rgba(201,168,76,.3);background:rgba(201,168,76,.07);}
  .un-box{background:var(--surface);border:1px solid var(--border-s);border-left:3px solid var(--gold);padding:2rem;}
  .un-lbl{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;display:block;}
  .un-item{margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border);}
  .un-item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none;}
  .un-title{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sky);margin-bottom:.35rem;}
  .un-cond{font-size:.85rem;color:rgba(255,255,255,.6);line-height:1.6;}
  .un-time{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.1em;color:var(--mid);margin-top:.35rem;display:block;}
  /* Recommendations */
  .rec-list{border:1px solid var(--border);}
  .rec-row{display:grid;grid-template-columns:58px 1fr;border-bottom:1px solid var(--border);transition:background .15s;}
  .rec-row:last-child{border-bottom:none;}
  .rec-row:hover{background:var(--surface);}
  .rec-num{font-family:'IBM Plex Mono',monospace;font-size:.6rem;color:var(--steel);padding:1.5rem;border-right:1px solid var(--border);display:flex;align-items:flex-start;padding-top:1.8rem;}
  .rec-body{padding:1.5rem 2rem;}
  .rec-action{font-family:'Playfair Display',serif;font-weight:700;font-size:1.05rem;color:var(--white);margin-bottom:.75rem;line-height:1.28;}
  .rec-action strong{color:var(--white);}
  .rec-specs{display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:.5rem;}
  .rec-spec{font-family:'IBM Plex Mono',monospace;font-size:.57rem;letter-spacing:.1em;color:var(--mid);}
  .rec-spec strong{color:var(--sky);}
  .rec-risk{font-size:.82rem;color:rgba(255,255,255,.5);line-height:1.58;margin-top:.6rem;padding-top:.6rem;border-top:1px solid var(--border);}
  /* Memory */
  .mw{background:var(--surface);border:1px solid var(--border);border-top:3px solid var(--steel);padding:2.5rem;margin-top:3rem;}
  .ms{margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid var(--border);}
  .ms:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none;}
  .mt{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--steel);display:block;margin-bottom:.85rem;}
  .mi{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
  .mi li{font-size:.87rem;color:rgba(255,255,255,.65);display:flex;gap:.7rem;line-height:1.58;}
  .mi li::before{content:'▸';color:var(--steel);flex-shrink:0;font-size:.62rem;padding-top:.18rem;}
  .mi li strong{color:var(--white);}
  .pred-log{display:flex;flex-direction:column;gap:0;border:1px solid var(--border);}
  .pl-row{display:grid;grid-template-columns:70px 1fr 80px;gap:1rem;padding:.75rem 1rem;border-bottom:1px solid var(--border);align-items:start;}
  .pl-row:last-child{border-bottom:none;}
  .pl-id{font-family:'IBM Plex Mono',monospace;font-size:.55rem;color:var(--mid);}
  .pl-text{font-size:.84rem;color:rgba(255,255,255,.7);line-height:1.6;}
  .pl-conf{font-family:'IBM Plex Mono',monospace;font-size:.52rem;letter-spacing:.12em;text-transform:uppercase;text-align:right;}
  .pc-h{color:var(--green);}.pc-m{color:var(--gold);}.pc-l{color:var(--mid);}
  /* Footer */
  footer{border-top:1px solid var(--border);padding:3rem;}
  .foot-bot{display:flex;justify-content:space-between;align-items:center;max-width:1140px;margin:0 auto;flex-wrap:wrap;gap:1.5rem;}
  .fb-brand{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:var(--steel);}
  .fb-brand em{font-style:italic;color:var(--sky);}
  .fl-row{display:flex;gap:2rem;flex-wrap:wrap;}
  .fl-row a{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);text-decoration:none;transition:color .2s;}
  .fl-row a:hover{color:var(--steel);}
  .fn{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:rgba(88,87,90,.6);letter-spacing:.08em;}
  /* Responsive */
  @media(max-width:960px){
    nav,.ih,footer{padding-left:1.5rem;padding-right:1.5rem;}
    .container{padding:0 1.5rem;}
    .sb-inner{grid-template-columns:repeat(3,1fr);padding:0 1.5rem;}
    .sw{grid-template-columns:1fr;}.st{position:static;}
    .ins-grid{grid-template-columns:1fr;}
    .hm-grid{grid-template-columns:repeat(3,1fr);}
    .ob2{grid-template-columns:1fr;}
    .pm-grid{grid-template-columns:1fr;}
    .bsc{grid-template-columns:1fr;}
    .ft{grid-template-columns:1fr;}
  }
  @media(max-width:600px){
    .hm-grid{grid-template-columns:repeat(2,1fr);}
    .sb-inner{grid-template-columns:repeat(2,1fr);}
  }
</style>
</head>
<body>

<nav>
  <a href="index.html" class="nb">Antifragile <span>Africa</span></a>
  <ul class="nl">
    <li><a href="index.html">Reports</a></li>
    <li><a href="about.html">About</a></li>
    <li><a href="{{ meta.filename or '#' }}" class="nav-cta">← Archive</a></li>
  </ul>
</nav>

{# ── ISSUE HEADER ── #}
<div class="ih">
  <div class="ih-inner">
    <div class="chips">
      <div class="chip"><span class="chip-l">Volume</span><span class="chip-v">{{ meta.vol }} of Series</span></div>
      <div class="chip-div"></div>
      <div class="chip"><span class="chip-l">Date</span><span class="chip-v">{{ meta.date }}</span></div>
      <div class="chip-div"></div>
      <div class="chip"><span class="chip-l">Audit</span><span class="chip-v">{{ meta.audit }} / 5.0 ✓</span></div>
      <div class="chip-div"></div>
      <div class="chip"><span class="chip-l">Agents</span><span class="chip-v">{{ meta.agents }} · {{ meta.layers }} Layers</span></div>
      {% if meta.new_signal %}
      <div class="chip-div"></div>
      <div class="chip"><span class="chip-l">New Signal</span><span class="chip-v">{{ meta.new_signal }}</span></div>
      {% endif %}
    </div>

    {% if meta.badges %}
    <div class="badges">
      {% for b in meta.badges %}
      <span class="badge {{ b.cls }}">{{ b.text }}</span>
      {% endfor %}
    </div>
    {% endif %}

    <div class="ih-date">{{ meta.date }} · Africa Crypto Intelligence OS</div>
    <h1 class="ih-title">{{ meta.title | title_html }}</h1>
    {% if meta.standfirst %}
    <p class="ih-sub">{{ meta.standfirst }}</p>
    {% endif %}
    <nav class="ih-nav">
      <a href="#brief">01 Brief</a><a href="#insights">02 Insights</a>
      <a href="#heatmap">03 Heat Map</a><a href="#fullstack">04 Full Stack</a>
      <a href="#fragility">05 Fragility</a><a href="#opps">06 Opportunities</a>
      <a href="#powermap">07 Power Map</a><a href="#blackswan">08 Black Swan</a>
      <a href="#snoise">09 Signal/Noise</a><a href="#recs">10 Recommendations</a>
    </nav>
  </div>
</div>

{# ── SPREAD BAR ── #}
{% set spreads = c.get('spreads', []) %}
{% if spreads %}
<div class="sb">
  <div class="sb-inner">
    {% for s in spreads %}
    <div class="sc">
      <div class="sc-country">{{ s.country }}</div>
      <div class="sc-val {{ s.val_cls }}">{{ s.val }}</div>
      <div class="sc-trend {{ s.trend_cls }}">{{ s.trend }}</div>
      {% if s.note %}<div class="sc-note">{{ s.note }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<div class="container">

{# ── 01 EXECUTIVE BRIEF ── #}
{% set brief = c.get('executive_brief', {}) %}
{% if brief %}
<section class="rs" id="brief">
  <div class="s-num">Component 01</div>
  <div class="s-ey">Executive Brief</div>
  <h2>Sovereign-Grade <em>Weekly Assessment</em></h2>
  <div class="eb">
    {% if brief.headline %}
    <div class="eb-hl">{{ brief.headline }}</div>
    {% endif %}
    <div class="eb-body">
      {% for para in brief.paragraphs %}
      {{ para | safe }}
      {% endfor %}
    </div>
    {% if brief.risk %}
    <div class="eb-risk"><strong>Key risk:</strong> {{ brief.risk | safe }}</div>
    {% endif %}
    {% if brief.summary %}
    <div class="eb-sum">{{ brief.summary | safe }}</div>
    {% endif %}
  </div>
</section>
{% endif %}

{# ── 02 INSIGHTS ── #}
{% set insights = c.get('insights', []) %}
{% if insights %}
<section class="rs" id="insights">
  <div class="s-num">Component 02</div>
  <div class="s-ey">Top Non-Obvious Insights</div>
  <h2>What Most Analysts <em>Won't Tell You</em></h2>
  <div class="ins-grid">
    {% for ins in insights %}
    <div class="ins-card" data-n="{{ ins.num }}">
      <div class="conf {{ ins.conf_cls }}">{{ ins.conf }} Confidence</div>
      <div class="ins-head">{{ ins.headline | safe }}</div>
      <div class="ins-body">{{ ins.body | safe }}</div>
      {% if ins.source %}
      <div class="ins-src">Source agents: {{ ins.source }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── 03 HEAT MAP ── #}
{% set hm = c.get('heatmap', {}) %}
{% if hm %}
<section class="rs" id="heatmap">
  <div class="s-num">Component 03</div>
  <div class="s-ey">Africa Crypto Momentum Map</div>
  <h2>Cycle {{ meta.vol }} <em>Country Scores</em></h2>

  {% for alert in hm.get('alerts', []) %}
  <div class="mv-alert">
    <span class="mv-label">{{ alert.label }}</span>
    <div class="mv-body">{{ alert.body | safe }}</div>
  </div>
  {% endfor %}

  {% set cells = hm.get('cells', []) %}
  {% if cells %}
  <div class="hm-grid">
    {% for cell in cells %}
    <div class="hm-cell {{ cell.border_cls }}">
      <div class="hm-country">{{ cell.country }}</div>
      <div class="hm-score {{ cell.score_cls }}">{{ cell.score }}</div>
      <div class="hm-trend {{ cell.trend_cls }}">{{ cell.trend }}</div>
      {% if cell.note %}<div class="hm-note">{{ cell.note }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if hm.caption %}
  <div class="hm-caption"><p>{{ hm.caption | safe }}</p></div>
  {% endif %}
</section>
{% endif %}

{# ── 04 FULL STACK ── #}
{% set fs = c.get('fullstack', {}) %}
{% if fs %}
<section class="rs" id="fullstack">
  <div class="s-num">Component 04</div>
  <div class="s-ey">Full Stack Analysis</div>
  <h2>12 Analytical Layers — <em>Cycle {{ meta.vol }}</em></h2>
  <div class="sw">
    <aside class="st">
      <span class="toc-l">Layers</span>
      <ul class="toc-list">
        {% for layer in fs.get('layers', []) %}
        <li><a href="#{{ layer.anchor }}">L{{ layer.num }} · {{ layer.name }}</a></li>
        {% endfor %}
        {% if fs.get('cross_insights') %}
        <li><a href="#scross">Cross-Layer</a></li>
        {% endif %}
      </ul>
    </aside>
    <div>
      {% for layer in fs.get('layers', []) %}
      <div class="sl" id="{{ layer.anchor }}">
        <div class="lb">Layer {{ layer.num }}</div>
        <div class="lt">{{ layer.name }}</div>
        <div class="lbody">
          {% if layer.orders %}
            {% for order in layer.orders %}
            <div class="ob">
              <div class="ot">{{ order.label }}</div>
              <div class="od">{{ order.text | safe }}</div>
            </div>
            {% endfor %}
          {% else %}
            {% for para in layer.paras %}
            {{ para | safe }}
            {% endfor %}
          {% endif %}
        </div>
      </div>
      {% endfor %}

      {% if fs.get('cross_insights') %}
      <div class="sl" id="scross">
        <div class="lb">Cross-Layer</div>
        <div class="lt">Cross-Layer Insights</div>
        <div class="cross-box">
          <span class="cross-lbl">Insights visible only from the synthesized stack</span>
          {% for ci in fs.cross_insights %}
          <div class="ci">
            <div class="ci-t">{{ ci.title | safe }}</div>
            <div class="ci-b">{{ ci.body | safe }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ── 05 FRAGILITY ── #}
{% set frag = c.get('fragility', {}) %}
{% if frag %}
<section class="rs" id="fragility">
  <div class="s-num">Component 05</div>
  <div class="s-ey">Fragility Index</div>
  <h2>Systemic Risk Assessment — <em>Cycle {{ meta.vol }}</em></h2>
  <div class="ft">
    <div>
      <div class="fs {{ frag.score_cls }}">{{ frag.score }}<span style="font-size:2rem;color:var(--mid)">/10</span></div>
    </div>
    <div class="fm">
      <div class="fst {{ frag.score_cls }}-color">● {{ frag.status }}</div>
      {% if frag.change %}
      <div style="font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--red);">{{ frag.change }}</div>
      {% endif %}
      {% if frag.desc %}
      <div class="fd">{{ frag.desc | safe }}</div>
      {% endif %}
    </div>
  </div>
  {% if frag.get('bars') %}
  <div class="fbars">
    {% for bar in frag.bars %}
    <div class="fr">
      <div class="frl">{{ bar.label }}</div>
      <div class="fbw"><div class="fb {{ bar.cls }}" style="width:{{ bar.width }}"></div></div>
      <div class="fv">{{ bar.val }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% if frag.get('risks') %}
  <div class="risks">
    {% for risk in frag.risks %}
    <div class="ri">
      <div class="rr">{{ risk.rank }}</div>
      <div>
        <div class="rn">{{ risk.name }}</div>
        <div class="rd">{{ risk.desc | safe }}</div>
      </div>
      <div class="rl {{ risk.level_cls }}">{{ risk.level }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endif %}

{# ── 06 OPPORTUNITIES ── #}
{% set opps = c.get('opportunities', []) %}
{% if opps %}
<section class="rs" id="opps">
  <div class="s-num">Component 06</div>
  <div class="s-ey">Asymmetric Opportunities</div>
  <h2>Hidden Trades — <em>Cycle {{ meta.vol }}</em></h2>
  <div class="opp-list">
    {% for opp in opps %}
    <div class="oc">
      <div class="oh">
        <div class="otb">{{ opp.tier }}</div>
        <div class="ott">{{ opp.title | safe }}</div>
        <div class="os">
          <div class="osn">{{ opp.score }}</div>
          <div class="osl">Asymmetry Score</div>
        </div>
      </div>
      <div class="ob2">
        <div class="oth">
          {% for para in opp.thesis_paragraphs %}
          {{ para | safe }}
          {% endfor %}
        </div>
        <div class="omc">
          {% for m in opp.meta %}
          <div>
            <span class="oml">{{ m.label }}</span>
            <span class="omv">{{ m.val }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
      {% if opp.invalidation %}
      <div class="oi"><strong>Invalidation:</strong> {{ opp.invalidation | safe }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── 07 POWER MAP ── #}
{% set pm = c.get('powermap', {}) %}
{% if pm %}
<section class="rs" id="powermap">
  <div class="s-num">Component 07</div>
  <div class="s-ey">Power Map</div>
  <h2>Control Architecture — <em>Cycle {{ meta.vol }}</em></h2>
  {% if pm.get('cards') %}
  <div class="pm-grid">
    {% for card in pm.cards %}
    <div class="pb">
      <div class="pb-title">{{ card.country }} — {{ card.status }}</div>
      {% for row in card.rows %}
      <div class="pr">
        <span class="p-lbl">{{ row.label }}</span>
        <span class="p-val {{ row.val_cls }}">{{ row.val }}</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% for shift in pm.get('shifts', []) %}
  <div class="psa {{ shift.border_cls }}">
    <span class="psa-lbl {{ shift.label_cls }}">{{ shift.label }}</span>
    <div class="psa-title">{{ shift.title }}</div>
    <div class="psa-desc">{{ shift.body | safe }}</div>
  </div>
  {% endfor %}
</section>
{% endif %}

{# ── 08 BLACK SWAN ── #}
{% set bsw = c.get('blackswan', c.get('black_swan', [])) %}
{% if bsw %}
<section class="rs" id="blackswan">
  <div class="s-num">Component 08</div>
  <div class="s-ey">Black Swan Watch</div>
  <h2>Tail Risk Scenario Library — <em>Cycle {{ meta.vol }}</em></h2>
  <div class="bs-list">
    {% for sc in bsw %}
    <div class="bsc {{ sc.card_cls }}">
      <div class="bs-pc">
        <div class="bs-pl">Probability</div>
        <div class="bs-pv">{{ sc.prob_val }}</div>
        <div class="bs-trend {{ sc.trend_cls }}">{{ sc.trend }}</div>
      </div>
      <div class="bs-bc">
        <h4>
          {{ sc.title | safe }}
          {% if sc.new_tag %}
          <span style="font-family:'IBM Plex Mono',monospace;font-size:.5rem;letter-spacing:.15em;text-transform:uppercase;color:var(--green);background:rgba(79,201,138,.08);border:1px solid rgba(79,201,138,.2);padding:.1rem .35rem;margin-left:.5rem;">★ New</span>
          {% endif %}
        </h4>
        {% for para in sc.paragraphs %}
        {{ para | safe }}
        {% endfor %}
        {% if sc.trigger %}
        <div class="bs-tr"><strong>Trigger signal:</strong> {{ sc.trigger | safe }}</div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── 09 SIGNAL / NOISE ── #}
{% set sn = c.get('signal_noise', c.get('signal_vs_noise', {})) %}
{% if sn %}
<section class="rs" id="snoise">
  <div class="s-num">Component 09</div>
  <div class="s-ey">Signal vs. Noise</div>
  <h2>Classification Table — <em>Cycle {{ meta.vol }}</em></h2>
  {% if sn.get('rows') %}
  <table class="sn-table">
    <thead>
      <tr><th>Development</th><th>Classification</th><th>Rationale</th></tr>
    </thead>
    <tbody>
      {% for row in sn.rows %}
      <tr>
        <td><span class="sn-dev">{{ row.dev }}</span></td>
        <td><span class="sn-b {{ row.cls }}">{{ row.badge }}</span></td>
        <td>{{ row.rationale }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if sn.get('unresolved') %}
  <div class="un-box">
    <span class="un-lbl">Unresolved Register · Active Monitoring</span>
    {% for ur in sn.unresolved %}
    <div class="un-item">
      <div class="un-title">{{ ur.title }}</div>
      {% if ur.condition %}<div class="un-cond">{{ ur.condition | safe }}</div>{% endif %}
      {% if ur.review %}<span class="un-time">Review: {{ ur.review }}</span>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endif %}

{# ── 10 RECOMMENDATIONS ── #}
{% set recs = c.get('recommendations', []) %}
{% if recs %}
<section class="rs" id="recs">
  <div class="s-num">Component 10</div>
  <div class="s-ey">Strategic Recommendations</div>
  <h2>Cycle {{ meta.vol }} <em>Actionable Intelligence</em></h2>
  <div class="rec-list">
    {% for rec in recs %}
    <div class="rec-row">
      <div class="rec-num">{{ rec.num }}</div>
      <div class="rec-body">
        <div class="rec-action">{{ rec.action | safe }}</div>
        <div class="rec-specs">
          {% if rec.for_whom %}<div class="rec-spec">For: <strong>{{ rec.for_whom }}</strong></div>{% endif %}
          {% if rec.timeframe %}<div class="rec-spec">Timeframe: <strong>{{ rec.timeframe }}</strong></div>{% endif %}
          {% if rec.trigger %}<div class="rec-spec">Trigger: <strong>{{ rec.trigger }}</strong></div>{% endif %}
        </div>
        {% if rec.risk %}<div class="rec-risk">{{ rec.risk | safe }}</div>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

{# ── MEMORY UPDATE ── #}
{% set mem = c.get('memory', {}) %}
{% if mem %}
  <div style="margin-top:4rem;padding-top:3rem;border-top:1px solid var(--border);">
    <div class="s-num">Memory Update</div>
    <div class="s-ey">Layer 7 — Cycle {{ meta.vol }} Logs</div>
    <div class="mw">
      {% if mem.get('trends') %}
      <div class="ms">
        <span class="mt">Trend Memory — Updates</span>
        <ul class="mi">
          {% for item in mem.trends %}<li>{{ item | safe }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if mem.get('countries') %}
      <div class="ms">
        <span class="mt">Country &amp; Entity Memory — Updates</span>
        <ul class="mi">
          {% for item in mem.countries %}<li>{{ item | safe }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if mem.get('resolved') %}
      <div class="ms">
        <span class="mt">Prediction Resolutions — Cycle {{ meta.vol }}</span>
        <ul class="mi">
          {% for item in mem.resolved %}<li>{{ item | safe }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if mem.get('predictions') %}
      <div class="ms">
        <span class="mt">New Predictions — Logged to Prediction Memory</span>
        <div class="pred-log">
          {% for p in mem.predictions %}
          <div class="pl-row">
            <div class="pl-id">{{ p.id }}</div>
            <div class="pl-text">{{ p.text | safe }}</div>
            <div class="pl-conf {{ p.conf_cls }}">{{ p.conf }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      {% if mem.get('watchlist') %}
      <div class="ms" style="margin-bottom:0;padding-bottom:0;border-bottom:none;">
        <span class="mt">Cycle {{ meta.next_vol or '' }} Watch Signals</span>
        <ul class="mi">
          {% for item in mem.watchlist %}<li>{{ item | safe }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
{% endif %}

</section>
{% endif %}

</div>{# /container #}

<footer>
  <div class="foot-bot">
    <div class="fb-brand">Antifragile <em>Africa</em> Crypto · Vol. {{ meta.vol }}</div>
    <div class="fl-row">
      <a href="index.html">All Reports</a>
      <a href="about.html">About</a>
      <a href="terms.html">Terms</a>
      <a href="privacy.html">Privacy</a>
      <a href="disclaimer.html">Disclaimer</a>
    </div>
    <span class="fn">© 2026 · Not financial advice · Simulated data where noted · For institutional use only</span>
  </div>
</footer>

<script>
const layers  = document.querySelectorAll('.sl[id]');
const tocLinks = document.querySelectorAll('.toc-list a');
if (layers.length) {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        tocLinks.forEach(l => { l.style.color = ''; l.style.borderLeftColor = 'transparent'; });
        const a = document.querySelector(`.toc-list a[href="#${e.target.id}"]`);
        if (a) { a.style.color = 'var(--sky)'; a.style.borderLeftColor = 'var(--steel)'; }
      }
    });
  }, { rootMargin: '-20% 0px -65% 0px' });
  layers.forEach(l => obs.observe(l));
}
</script>
</body>
</html>
